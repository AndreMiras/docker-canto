VERSION=8.1.3
# Chain ID (default: canto_7700-1)
# CHAIN_ID=canto_7700-1
# Node moniker (default: moniker)
# CONFIG_MONIKER=my-canto-node
# State sync
CONFIG_STATESYNC_ENABLE=true
CONFIG_STATESYNC_RPC_SERVERS=https://canto-rpc.polkachu.com:443,https://canto-rpc.polkachu.com:443
# https://www.publicnode.com/
CONFIG_P2P_SEEDS=8542cd7e6bf9d260fef543bc49e59be5a3fa9074@seed.publicnode.com:26656
# Pruning (default|nothing|everything|custom)
# APP_PRUNING=default
# Logging
# CONFIG_LOG_LEVEL=info
# Suppress entrypoint logs
# CANTO_ENTRYPOINT_QUIET_LOGS=1
CONFIG_INSTRUMENTATION_PROMETHEUS=true
APP_API_ENABLE=true
APP_TELEMETRY_ENABLED=true
APP_TELEMETRY_PROMETHEUS_RETENTION_TIME=60
# Traefik reverse proxy (enable with: docker compose --profile proxy up)
# TRAEFIK_LOG_LEVEL=ERROR
# TRAEFIK_ACCESS_LOG=false
# Rate limiting (applied via Go templates in config/etc/traefik/dynamic.yml)
# RATE_LIMIT_AVERAGE=60
# RATE_LIMIT_PERIOD=1m
# RATE_LIMIT_BURST=20
